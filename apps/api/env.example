# Server Configuration
NODE_ENV=development
PORT=3101

# PostgreSQL Database URL
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/strikeshop?schema=public"
# Optional: pooled runtime URL (PgBouncer/provider pool). If omitted, DATABASE_URL is used.
# DATABASE_POOL_URL="postgresql://postgres:postgres@localhost:5432/strikeshop?schema=public"
# API pool limits (safe defaults for small server)
PRISMA_POOL_MAX=3
PRISMA_POOL_IDLE_TIMEOUT_MS=5000
PRISMA_POOL_CONNECTION_TIMEOUT_MS=5000

# MongoDB URI
MONGODB_URI="mongodb://localhost:27017/strikeshop"

# JWT Configuration
JWT_SECRET="Kx9#mP2@nQ4%wR6^tY1&uI3*oE7+pA5{sD0}zF9|cG2:hJ4<kL6>mN8?bV0[xC2]yZ4\;qW6',rT8./sU0"

