{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "src",
  "compilerOptions": {
    "deleteOutDir": true,
    "assets": [
      {
        "include": "generated/**/*",
        "exclude": "**/*.ts",
        "watchAssets": true,
        "outDir": "dist/src"
      },
      {
        "include": "email/templates/**/*.hbs",
        "exclude": "**/*.ts",
        "watchAssets": true,
        "outDir": "dist/src"
      }
    ]
  }
}
