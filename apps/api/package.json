{
  "name": "api",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "dev": "nest start --watch",
    "prebuild": "prisma generate --schema=./prisma/schema.prisma",
    "build": "nest build",
    "postbuild": "prisma migrate deploy --schema=./prisma/schema.prisma && npm run seed:template",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "node dist/index.js",
    "start:dev": "npm run seed:template && nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "prisma:generate": "prisma generate",
    "prisma:migrate:dev": "prisma migrate dev --name init",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:push": "prisma db push",
    "prisma:prepare": "prisma generate && prisma db push --force-reset --accept-data-loss",
    "setup": "prisma generate && prisma migrate deploy && npm run seed:products",
    "seed:admin": "ts-node -r tsconfig-paths/register src/seeds/seed-admin.ts",
    "seed:regions": "ts-node -r tsconfig-paths/register src/seeds/seed-regions.ts",
    "seed:template": "ts-node -r tsconfig-paths/register src/seeds/seed-template.ts",
    "seed:cities": "ts-node -r tsconfig-paths/register src/seeds/seed-cities.ts",
    "seed:products": "ts-node -r tsconfig-paths/register src/seeds/seed-products.ts",
    "seed:events": "ts-node -r tsconfig-paths/register src/seeds/seed-events.ts",
    "seed:teams": "ts-node -r tsconfig-paths/register src/seeds/seed-teams.ts",
    "seed:ratings": "ts-node -r tsconfig-paths/register src/seeds/seed-ratings.ts",
    "seed:event-owner": "ts-node -r tsconfig-paths/register src/seeds/seed-event-owner.ts",
    "setup:db": "npm run prisma:prepare && npm run seed:admin && npm run seed:regions && npm run seed:cities && npm run seed:teams && npm run seed:products && npm run seed:events && npm run seed:template && npm run seed:ratings"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.10",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.1.10",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/mapped-types": "*",
    "@nestjs/mongoose": "^11.0.4",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.10",
    "@nestjs/schedule": "^6.1.1",
    "@prisma/adapter-pg": "^7.2.0",
    "@prisma/client": "^7.3.0",
    "@sendgrid/mail": "^8.1.6",
    "@types/bcrypt": "^6.0.0",
    "@types/express": "^5.0.6",
    "@types/multer": "^2.0.0",
    "@types/node": "^25.0.3",
    "@types/nodemailer": "^7.0.4",
    "@types/passport-facebook": "^3.0.4",
    "@types/passport-google-oauth20": "^2.0.17",
    "@types/pg": "^8.16.0",
    "@vercel/blob": "^2.0.0",
    "bcrypt": "^6.0.0",
    "class-transformer": "^0.5",
    "class-validator": "^0.14",
    "dotenv": "^17.2.3",
    "handlebars": "^4.7.8",
    "mongoose": "^9.0.2",
    "nodemailer": "^7.0.12",
    "passport": "^0.7.0",
    "passport-facebook": "^3.0.0",
    "passport-google-oauth20": "^2.0.0",
    "pdfkit": "^0.17.2",
    "pg": "^8.16.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7",
    "sanitize-html": "^2.17.3",
    "sharp": "^0.34.5",
    "transliteration": "^2.6.0",
    "zod": "^4.2.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.3",
    "@eslint/js": "^9.39.2",
    "@nestjs/cli": "^11.0.14",
    "@nestjs/schematics": "^11.0.9",
    "@nestjs/testing": "^11.1.10",
    "@swc/cli": "^0.7.9",
    "@swc/core": "^1.15.7",
    "@swc/jest": "^0.2.36",
    "@types/jest": "^30.0.0",
    "@types/pdfkit": "^0.17.5",
    "@types/sanitize-html": "^2.16.1",
    "@types/supertest": "^6.0.3",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "globals": "^16.5.0",
    "jest": "^30.2.0",
    "prettier": "^3.7.4",
    "prisma": "^7.3.0",
    "source-map-support": "^0.5.21",
    "supertest": "^7.1.4",
    "ts-loader": "^9.5.4",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.50.1"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": [
        "@swc/jest"
      ]
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "coverageProvider": "v8",
    "testEnvironment": "node"
  }
}
