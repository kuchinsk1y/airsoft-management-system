<!DOCTYPE html>
<html lang="uk" xmlns="http://www.w3.org/1999/xhtml" xmlns:v="urn:schemas-microsoft-com:vml"
  xmlns:o="urn:schemas-microsoft-com:office:office">

<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta http-equiv="X-UA-Compatible" content="IE=edge">
  <meta name="x-apple-disable-message-reformatting">
  <meta name="format-detection" content="telephone=no,address=no,email=no,date=no,url=no">
  <title>{{heading}}</title>
  <link href="https://fonts.googleapis.com/css2?family=Sofia+Sans:wght@400;700&display=swap" rel="stylesheet">
  <style type="text/css">
    table {
      border-collapse: collapse;
    }

    body {
      margin: 0 !important;
      padding: 0 !important;
      width: 100% !important;
      font-family: 'Sofia Sans', Arial, Helvetica, sans-serif !important;
    }

    img {
      border: 0;
      outline: none;
      text-decoration: none;
      -ms-interpolation-mode: bicubic;
      height: auto;
    }

    .email-outer-pad {
      padding: 8px !important;
    }

    .email-inset {
      padding: 10px 16px !important;
    }

    .email-header-bar {
      padding: 32px 36px !important;
    }

    .email-content-inset {
      padding: 52px 20px 300px !important;
    }

    .email-footer-inset {
      padding: 40px 40px 40px 80px !important;
    }

    .email-h1 {
      font-size: 20px !important;
      line-height: 1.35 !important;
    }

    .email-body-lead {
      margin-bottom: 40px !important;
    }

    .footer-social-list span {
      display: block !important;
      margin-bottom: 14px !important;
    }

    .footer-social-list span:last-child {
      margin-bottom: 0 !important;
    }

    @media only screen and (min-width: 641px) {
      .email-outer-pad {
        padding: 14px !important;
      }

      .email-inset {
        padding: 12px 64px !important;
      }

      .email-header-bar {
        padding: 32px 36px !important;
      }

      .email-content-inset {
        padding: 88px 64px 300px !important;
      }

      .email-footer-inset {
        padding: 40px 40px 40px 80px !important;
      }

      .email-h1 {
        font-size: 22px !important;
      }

      .email-body-lead {
        margin-bottom: 48px !important;
      }
    }

    @media only screen and (max-width: 640px) {
      .email-header-bar {
        padding: 24px 16px !important;
      }

      .email-header-nav td {
        font-size: 11px !important;
        padding-left: 8px !important;
      }

      .email-header-nav td:first-child {
        padding-left: 0 !important;
      }

      .email-header-logo-gap {
        width: 20px !important;
      }

      .footer-col {
        display: block !important;
        width: 100% !important;
        max-width: 100% !important;
        padding: 0 0 24px 0 !important;
      }

      .email-cta {
        padding: 14px 28px !important;
        font-size: 13px !important;
      }

      .email-footer-inset {
        padding: 32px 20px !important;
      }

      .footer-col-mid {
        padding-right: 24px !important;
      }

      .footer-social-col-first {
        padding-right: 9px !important;
      }
    }
  </style>
</head>

<body style="margin:0;padding:0;background-color:#141414;-webkit-text-size-adjust:100%;-ms-text-size-adjust:100%;">
  <table role="presentation" cellspacing="0" cellpadding="0" border="0" width="100%"
    style="width:100%;background-color:#141414;">
    <tr>
      <td align="center" class="email-outer-pad" style="padding:8px;">
        <table role="presentation" cellspacing="0" cellpadding="0" border="0" width="100%"
          style="width:100%;max-width:100%;border:2px solid #ffffff;border-collapse:collapse;mso-table-lspace:0pt;mso-table-rspace:0pt;">

          <tr>
            <td class="email-header-bar"
              style="border-bottom:1px solid #ffffff;background-color:#000000;padding:32px 36px;">
              <table role="presentation" cellspacing="0" cellpadding="0" border="0" align="center"
                style="margin:0 auto;width:auto;">
                <tr>
                  <td valign="middle" align="center" style="padding:0;width:140px;min-width:140px;">
                    <img src="{{headerLogoUrl}}" alt="Strikeshop Action" width="140"
                      style="display:block;border:0;max-width:140px;width:140px;height:auto;">
                  </td>
                  <td class="email-header-logo-gap" valign="middle" width="40"
                    style="width:40px;min-width:40px;font-size:0;line-height:0;">&nbsp;</td>
                  <td valign="middle" align="left" style="padding:0;">
                    <table role="presentation" class="email-header-nav" cellspacing="0" cellpadding="0" border="0">
                      <tr>
                        <td
                          style="color:#ffffff;font-family:'Sofia Sans',Arial,Helvetica,sans-serif;font-size:10px;font-style:normal;font-weight:400;line-height:normal;text-transform:uppercase;padding:0;white-space:nowrap;">
                          <a href="{{siteUrl}}/events" target="_blank"
                            style="color:#ffffff;text-decoration:none;">Календар подій</a></td>
                        <td
                          style="color:#ffffff;font-family:'Sofia Sans',Arial,Helvetica,sans-serif;font-size:10px;font-style:normal;font-weight:400;line-height:normal;text-transform:uppercase;padding:0 0 0 20px;white-space:nowrap;">
                          <a href="{{siteUrl}}/services" target="_blank"
                            style="color:#ffffff;text-decoration:none;">Послуги</a></td>
                        <td
                          style="color:#ffffff;font-family:'Sofia Sans',Arial,Helvetica,sans-serif;font-size:10px;font-style:normal;font-weight:400;line-height:normal;text-transform:uppercase;padding:0 0 0 20px;white-space:nowrap;">
                          <a href="{{siteUrl}}/about" target="_blank"
                            style="color:#ffffff;text-decoration:none;">Про нас</a></td>
                        <td
                          style="color:#ffffff;font-family:'Sofia Sans',Arial,Helvetica,sans-serif;font-size:10px;font-style:normal;font-weight:400;line-height:normal;text-transform:uppercase;padding:0 0 0 20px;white-space:nowrap;">
                          <a href="{{siteUrl}}/contacts" target="_blank"
                            style="color:#ffffff;text-decoration:none;">Контакти</a></td>
                      </tr>
                    </table>
                  </td>
                </tr>
              </table>
            </td>
          </tr>

          <tr>
            <td class="email-content-inset" align="center" style="padding:52px 20px 300px;background-color:#000000;">
              <table role="presentation" cellspacing="0" cellpadding="0" border="0" width="100%"
                style="width:100%;max-width:100%;">
                <tr>
                  <td align="center"
                    style="font-family:'Sofia Sans',Arial,Helvetica,sans-serif;color:#ffffff;word-wrap:break-word;overflow-wrap:break-word;">
                    <h1 class="email-h1"
                      style="margin:0 0 28px;padding:0;font-size:20px;font-weight:700;line-height:1.35;color:#ffffff;text-transform:uppercase;letter-spacing:0.04em;text-align:center;">
                      {{heading}}
                    </h1>
                    <div class="email-body-lead"
                      style="font-size:13px;line-height:1.75;color:#ffffff;text-transform:uppercase;letter-spacing:0.05em;text-align:center;margin:0 0 40px;">
                      {{{stripLinks bodyHtml}}}
                    </div>
                    {{#if ctaUrl}}
                    <table role="presentation" cellspacing="0" cellpadding="0" border="0" align="center"
                      style="margin:0 auto;">
                      <tr>
                        <td align="center" bgcolor="#FF4500" style="border-radius:2px;">
                          <a href="{{ctaUrl}}" target="_blank" class="email-cta"
                            style="display:inline-block;padding:16px 40px;font-family:'Sofia Sans',Arial,Helvetica,sans-serif;font-size:14px;font-weight:700;line-height:1.2;color:#ffffff;text-decoration:none;text-transform:uppercase;letter-spacing:0.08em;">{{ctaText}}</a>
                        </td>
                      </tr>
                    </table>
                    {{/if}}
                    {{#if secondaryText}}
                    <p
                      style="margin:36px 0 0;padding:0;font-size:13px;line-height:1.5;text-align:center;text-transform:none;letter-spacing:normal;color:#ffffff;">
                      {{secondaryText}}
                    </p>
                    {{/if}}
                  </td>
                </tr>
              </table>
            </td>
          </tr>

          <tr>
            <td style="background-color:#000000;border-top:1px solid #ffffff;padding:0;">
              <table role="presentation" cellspacing="0" cellpadding="0" border="0" width="100%"
                style="width:100%;background-color:#000000;">
                <tr>
                  <td class="email-footer-inset"
                    style="padding:40px 40px 40px 80px;font-family:'Sofia Sans',Arial,Helvetica,sans-serif;color:#ffffff;">
                    <table role="presentation" cellspacing="0" cellpadding="0" border="0" width="100%"
                      style="width:100%;">
                      <tr>
                        <td valign="top" width="33%" class="footer-col"
                          style="padding:0 32px 20px 0;vertical-align:top;">
                          <img src="{{footerLogoUrl}}" alt="Strikeshop Action" width="140"
                            style="display:block;border:0;max-width:140px;width:140px;height:auto;margin-bottom:20px;">
                          <p
                            style="margin:0;padding:0;font-size:16px;line-height:1.55;font-weight:400;color:#ffffff;text-transform:uppercase;letter-spacing:0.06em;">
                            Відчуй адреналін — живи пригодами!
                          </p>
                        </td>
                        <td valign="top" width="34%" class="footer-col footer-col-mid"
                          style="padding:0 64px 20px 12px;vertical-align:top;">
                          <p
                            style="margin:0 0 18px;padding:0;font-size:14px;font-weight:700;color:#ffffff;text-transform:uppercase;letter-spacing:0.06em;">
                            Адреса офісу</p>
                          <p
                            style="margin:0 0 20px;padding:0;font-size:10px; font-weight:400;line-height:1.45;color:#ffffff;text-transform:uppercase;">
                            Київ, Саксаганського, 42/80</p>
                          <p
                            style="margin:0 0 18px;padding:0;font-size:14px;font-weight:700;color:#ffffff;text-transform:uppercase;letter-spacing:0.06em;">
                            Зв'яжіться з нами</p>
                          <p style="margin:0 0 4px;padding:0;font-size:10px;font-weight:400;color:#ffffff;">
                            <a href="tel:+380971672730" style="color:#ffffff;text-decoration:none;">+38 (097)
                              167-27-30</a>
                          </p>
                          <p style="margin:0;padding:0;font-size:10px;font-weight:400;color:#ffffff;">
                            <a href="tel:+380993466826" style="color:#ffffff;text-decoration:none;">+38 (099)
                              346-58-26</a>
                          </p>
                        </td>
                        <td valign="top" width="33%" class="footer-col" style="padding:0 0 20px 0;vertical-align:top;">
                          <p
                            style="margin:0 0 18px;padding:0;font-size:14px;font-weight:700;color:#ffffff;text-transform:uppercase;letter-spacing:0.06em;">
                            Слідкуйте за нами</p>
                          <table role="presentation" cellspacing="0" cellpadding="0" border="0" align="left"
                            style="width:auto;">
                            <tr>
                              <td valign="top" class="footer-social-col-first footer-social-list"
                                style="font-size:10px;line-height:1.2;font-weight:400;color:#ffffff;text-transform:uppercase;letter-spacing:0.04em;padding:0 24px 0 0;white-space:nowrap;">
                                <span><a href="{{siteUrl}}/contacts" target="_blank"
                                  style="color:#ffffff;text-decoration:none;">Facebook</a></span>
                                <span><a href="{{siteUrl}}/contacts" target="_blank"
                                  style="color:#ffffff;text-decoration:none;">Instagram</a></span>
                                <span><a href="https://t.me/StrikeshopActionUkraine" target="_blank"
                                  style="color:#ffffff;text-decoration:none;">Telegram</a></span>
                              </td>
                              <td valign="top" class="footer-social-list"
                                style="font-size:10px;line-height:1.2;font-weight:400;color:#ffffff;text-transform:uppercase;letter-spacing:0.04em;white-space:nowrap;">
                                <span><a href="{{siteUrl}}/contacts" target="_blank"
                                  style="color:#ffffff;text-decoration:none;">Discord</a></span>
                                <span><a href="{{siteUrl}}/contacts" target="_blank"
                                  style="color:#ffffff;text-decoration:none;">YouTube</a></span>
                                <span><a href="{{siteUrl}}/contacts" target="_blank"
                                  style="color:#ffffff;text-decoration:none;">TikTok</a></span>
                              </td>
                            </tr>
                          </table>
                        </td>
                      </tr>
                      <tr>
                        <td colspan="3" style="padding:16px 0 0;">
                          <table role="presentation" cellspacing="0" cellpadding="0" border="0" width="100%">
                            <tr>
                              <td align="left"
                                style="font-size:10px;font-weight:400;color:#ffffff;text-transform:uppercase;letter-spacing:0.06em;">
                                Strikeshop Action, {{currentYear}}</td>
                              <td align="right"
                                style="font-size:10px;font-weight:400;color:#ffffff;text-transform:uppercase;letter-spacing:0.06em;">
                                Всі права захищені</td>
                            </tr>
                          </table>
                        </td>
                      </tr>
                    </table>
                  </td>
                </tr>
              </table>
            </td>
          </tr>

        </table>
      </td>
    </tr>
  </table>
</body>

</html>