{{#if isApproved}}
{{> strike-email
  heading=subject
  bodyHtml=(concat
    "<p style=\"margin:0 0 16px;\">Вашу заявку на створення події «"
    eventName
    "» схвалено.</p><p style=\"margin:0;\">Подію опубліковано на сайті та відкрито для реєстрації.</p>"
  )
  ctaText="Переглянути подію"
  ctaUrl=eventLink
}}
{{else}}
{{> strike-email
  heading=subject
  bodyHtml=(concat
    "<p style=\"margin:0 0 16px;\">Вашу заявку на створення події «"
    eventName
    "» відхилено.</p>"
  )
  secondaryText=secondaryText
}}
{{/if}}
